{
  "name": "sipi-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:graph": "node scripts/build_graph.mjs",
    "wiki:ops": "node scripts/update_wiki_ops.mjs",
    "lint:wiki": "node scripts/lint_wiki.mjs",
    "init:knowledge": "node scripts/init_knowledge_intake.mjs",
    "scan:knowledge": "node scripts/scan_knowledge_sources.mjs",
    "register:knowledge": "node scripts/register_knowledge_intake.mjs && node scripts/register_docling_sources.mjs && node scripts/build_graph.mjs",
    "register:docling": "node scripts/register_docling_sources.mjs && node scripts/build_graph.mjs",
    "register:raw-sources": "node scripts/register_raw_source_inventory.mjs && node scripts/build_graph.mjs",
    "register:strategies": "node scripts/register_design_strategies.mjs && node scripts/build_graph.mjs",
    "register:formulas": "node scripts/register_formulas.mjs && node scripts/build_graph.mjs",
    "export:obsidian": "node scripts/export_obsidian_vault.mjs",
    "register:tools": "node scripts/register_tool_connectors.mjs && node scripts/build_graph.mjs",
    "setup:pdf-python": "node scripts/run_ads_python.mjs scripts/bootstrap_pdf_python_deps.py",
    "check:pdf-python": "node scripts/run_ads_python.mjs scripts/bootstrap_pdf_python_deps.py --check-only",
    "report:wiki-strategy": "node scripts/run_ads_python.mjs scripts/generate_wiki_strategy_report.py",
    "plan:bench-adapter": "node scripts/run_ads_python.mjs scripts/create_bench_adapter_plan.py",
    "bench:ads-from-strategy": "node scripts/run_ads_python.mjs scripts/run_ads_bench_from_strategy.py",
    "report:stages": "node scripts/run_ads_python.mjs scripts/generate_stage_pdf_reports.py",
    "report:checkpoint": "node scripts/run_ads_python.mjs scripts/stage_report_checkpoint.py",
    "extract:spec-evidence": "node scripts/run_ads_python.mjs scripts/extract_spec_evidence.py",
    "extract:pdf-evidence": "node scripts/run_ads_python.mjs scripts/extract_pdf_figure_evidence.py",
    "setup:docling": "node scripts/run_python.mjs -m pip install -r requirements-docling.txt",
    "check:docling": "node scripts/run_python.mjs scripts/ingest_docling_sources.py --check",
    "ingest:docling": "node scripts/run_python.mjs scripts/ingest_docling_sources.py",
    "smoke:kicad-mcp": "node scripts/smoke_kicad_mcp.mjs",
    "harness:dry-run": "node scripts/run_ads_python.mjs scripts/run_harness.py --dry-run",
    "smoke:sample": "node scripts/run_ads_python.mjs scripts/check_sample_case.py",
    "docs:list": "node -e \"console.log(['docs/architecture.md','docs/input_contract.md','docs/workflow.md','docs/validation_rules.md','docs/human_checkpoints.md','docs/adapting_to_new_case.md','docs/external_tools.md','docs/assets/harness_overview.png'].join('\\n'))\"",
    "route:astar": "node scripts/astar_grid_router.mjs",
    "create:channel-case": "node scripts/run_python.mjs scripts/create_generic_channel_case.py",
    "estimate:trace-width": "node scripts/run_python.mjs scripts/estimate_trace_width.py",
    "check:kicad-geometry": "node scripts/run_ads_python.mjs scripts/check_kicad_same_layer_geometry.py",
    "check:port-launch": "node scripts/run_ads_python.mjs scripts/check_port_intent_launch_clearance.py",
    "render:kicad-preview": "node scripts/run_ads_python.mjs scripts/render_kicad_layout_preview.py",
    "finalize:kicad-microstrip": "node scripts/finalize_microstrip_coupon.mjs",
    "demo:kicad-microstrip": "node scripts/create_microstrip_50ohm_board.mjs && node scripts/finalize_microstrip_coupon.mjs",
    "export:hfss3dlayout": "node scripts/export_kicad_hfss3dlayout.mjs",
    "import:hfss3dlayout": "node scripts/run_aedt_python.mjs scripts/import_odb_to_hfss3dlayout_project.py --version 2025.1 --non-graphical --overwrite",
    "fix:hfss3dlayout-stackup": "node scripts/run_aedt_python.mjs scripts/fix_hfss3dlayout_stackup.py --version 2025.1 --overwrite",
    "setup:aedt-python": "node scripts/run_aedt_python.mjs --install-deps",
    "solve:hfss3dlayout-touchstone": "node scripts/run_aedt_python.mjs scripts/solve_hfss3dlayout_touchstone.py",
    "solve:hfss3dlayout-microstrip": "node scripts/run_aedt_python.mjs scripts/run_hfss3dlayout_microstrip_snp.py --source-aedb ../outputs/hfss3dlayout_import/microstrip_50ohm_fr4_1p6_edge.aedb --work-aedb ../outputs/hfss3dlayout_import/microstrip_50ohm_fr4_1p6_edge_solve.aedb --touchstone ../outputs/hfss3dlayout_import/microstrip_50ohm_fr4_1p6_edge_solve.s2p --summary ../outputs/hfss3dlayout_import/microstrip_solve_summary.json --version 2025.1 --setup Setup_3xNyq --sweep Sweep_0p01_6G_121 --adaptive-ghz 6 --start-ghz 0.01 --stop-ghz 6 --points 121 --sweep-type Fast --port-method edb_gap --overwrite --non-graphical",
    "smoke:hfss3dlayout-microstrip": "npm run demo:kicad-microstrip && npm run export:hfss3dlayout && npm run import:hfss3dlayout -- --odb ../outputs/hfss3dlayout_import/microstrip_50ohm_fr4_1p6_odb.zip --project ../outputs/hfss3dlayout_import/microstrip_50ohm_fr4_1p6_edge.aedt --summary ../outputs/hfss3dlayout_import/microstrip_import_summary.json --kicad-board ../outputs/kicad_microstrip_50ohm/microstrip_50ohm_fr4_1p6.kicad_pcb --prefer-direct-edb --port-method edb_polygon_edge --edge-port-type Gap --version 2025.1 --non-graphical --overwrite && npm run solve:hfss3dlayout-microstrip",
    "create:hfss3dlayout-circuit-ports": "node scripts/run_aedt_python.mjs scripts/run_hfss3dlayout_microstrip_oeditor_circuit_ports.py --version 2025.1 --overwrite --skip-solve",
    "solve:hfss3d-microstrip": "node scripts/run_aedt_python.mjs scripts/run_hfss3d_microstrip_snp.py --non-graphical",
    "create:ads-channel": "node scripts/run_ads_python.mjs scripts/create_ads_channel_workspace.py --overwrite",
    "create:ads-schematic": "node scripts/run_ads_python.mjs scripts/create_ads_channel_schematic.py",
    "solve:ads-channel": "node scripts/run_ads_python.mjs scripts/run_ads_channel_sim.py",
    "bench:sparameter": "node scripts/run_ads_python.mjs scripts/create_sparameter_bench_report.py",
    "bench:ads-workspace": "node scripts/run_ads_python.mjs scripts/create_ads_bench_templates.py",
    "bench:ads-templates": "node scripts/run_ads_python.mjs scripts/create_ads_bench_templates.py",
    "bench:ads-per-lane-eye": "node scripts/run_ads_python.mjs scripts/run_ads_per_lane_eye_report.py",
    "touchstone:reorder-ports": "node scripts/run_python.mjs scripts/reorder_touchstone_ports.py",
    "touchstone:resample-eye": "node scripts/run_python.mjs scripts/resample_touchstone_for_eye.py",
    "check:ads-workspace": "node scripts/run_python.mjs scripts/check_ads_workspace.py",
    "export:hfss3dlayout-existing": "node scripts/run_python.mjs scripts/run_aedt_native_export.py",
    "export:hfss3dlayout-native": "node scripts/run_python.mjs scripts/run_aedt_native_export.py",
    "smoke:ads-python": "node scripts/run_ads_python.mjs scripts/ads_import_smoke.py",
    "verify:hfss3dlayout": "node scripts/run_aedt_python.mjs scripts/verify_hfss3dlayout_aedb.py --version 2025.1",
    "refresh:all": "node scripts/register_knowledge_intake.mjs && node scripts/register_raw_source_inventory.mjs && node scripts/register_docling_sources.mjs && node scripts/register_design_strategies.mjs && node scripts/register_formulas.mjs && node scripts/register_tool_connectors.mjs && node scripts/build_graph.mjs && node scripts/update_wiki_ops.mjs && node scripts/export_obsidian_vault.mjs",
    "serve": "node scripts/serve.mjs",
    "prompt:intake": "node scripts/print_intake_prompt.mjs",
    "prompt:stage-review": "node scripts/print_stage_review_prompt.mjs"
  }
}
